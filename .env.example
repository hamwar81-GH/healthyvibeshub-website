# ─── Healthy Vibes Hub — Environment Variables ───
# Copy this file to .env.local and fill in real values

# Site
NEXT_PUBLIC_SITE_URL=https://healthyvibeshub.com
NEXT_PUBLIC_SITE_NAME=Healthy Vibes Hub

# Google Analytics 4 (replace with your measurement ID)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense (replace with your publisher ID)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Newsletter (Mailchimp or ConvertKit API)
# NEXT_PUBLIC_MAILCHIMP_URL=https://youraccount.us1.list-manage.com/subscribe/post?u=xxx&id=yyy
# CONVERTKIT_API_KEY=your_api_key
# CONVERTKIT_FORM_ID=your_form_id

# Contact Form (EmailJS or Resend)
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxx
# RESEND_API_KEY=re_xxx

# Social
NEXT_PUBLIC_TWITTER_HANDLE=@healthyvibeshub
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/healthyvibeshub
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@healthyvibeshub
NEXT_PUBLIC_PINTEREST_URL=https://www.pinterest.com/healthyvibeshub
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@healthyvibeshub
